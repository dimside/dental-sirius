---
const services = [
  { title: 'Консультація', price: '500 грн.' },
  { title: 'Гігієна порожнини рота', price: '500 грн.' },
  { title: 'Дослідження та діагностика', price: '500 грн.' },
  { title: 'Лікування ясен', price: '500 грн.' },
  { title: 'Лікування зубів', price: '500 грн.' },
  { title: 'Протезування зубів', price: '500 грн.' },
  { title: 'Ендодонтія (лікування каналів)', price: '500 грн.' },
  { title: 'Естетична стоматологія', price: '500 грн.' },
];
---

<section id="prices" class="prices">
  <div class="container">
    <div class="wrapper">
      <h2 class="title-h2">Вартість наших послуг</h2>
      <ul class="ul-list">
        {
          services.map((service) => (
            <li class="li-item">
              <>
                <span class="service">{service.title}</span>
                <span class="price">{service.price}</span>
              </>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .title-h2 {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-color-black);
    text-align: center;
    gap: 20px;
  }
  .title-h2::before,
  .title-h2::after {
    content: '';
    display: inline-block;
    width: 19px;
    height: 4px;
    background-color: var(--main-color);
    flex-shrink: 0;
  }

  .ul-list {
    margin-top: 40px;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    padding: 0;
  }
  .li-item {
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 15px;
    gap: 20px;
  }
  .li-item:not(:last-child) {
    border-bottom: 1px solid rgba(47, 158, 136, 0.4);
  }
  .service {
    font-weight: 700;
    font-size: 18px;
    line-height: 1.625;
    flex: 1;
    color: var(--text-color-black);
  }
  .price {
    font-weight: 500;
    font-size: 16px;
    line-height: 1.625;
    flex-shrink: 0;
    white-space: nowrap;
    color: var(--text-color-price);
  }
  @media (min-width: 768px) {
    .title-h2::before,
    .title-h2::after {
      width: 25px;
    }
    .ul-list {
      margin-top: 60px;
    }
  }
  @media (min-width: 1200px) {
    .ul-list {
      margin-top: 70px;
    }
  }
</style>
