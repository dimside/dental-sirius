---
import '../styles/main.css';
import close from '../assets/icons/close.svg?url';
---

<div class="modal-overlay is-hidden" id="callback-modal">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="callback-title">
    <button class="modal-close" id="modal-close" aria-label="Закрити вікно">
      <img src={close} alt="" />
    </button>

    <h3 class="modal-title">Зворотній дзвінок</h3>

    <form id="callback-form" class="modal-form">
      <div class="field">
        <input
          type="text"
          name="name"
          placeholder="Ваше ім’я"
          class="modal-input"
          autocomplete="name"
        />
        <p class="error" data-error="name"></p>
      </div>

      <div class="field">
        <input
          type="tel"
          name="phone"
          placeholder="Ваш номер телефону (088-123-45-67)"
          class="modal-input"
          autocomplete="tel"
        />
        <p class="error" data-error="phone"></p>
      </div>

      <!-- Honeypot и таймер -->
      <input type="text" name="_honeypot" style="display:none" />
      <input type="hidden" name="startTime" value="" />

      <!-- Блок для ответа сервера -->
      <div id="form-response" class="form-response"></div>

      <button type="submit" class="modal-btn"> ЗАЛИШИТИ ЗАЯВКУ </button>
    </form>

    <p class="modal-policy">
      Натискаючи на кнопку, ви погоджуєтесь з
      <span class="personal-data">умовами обробки персональних даних</span>
    </p>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background-color: var(--modal-overlay-color);
    display: flex;
    justify-content: center;
    align-items: end;
    z-index: 1000;

    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);

    opacity: 1;
    transition: all 0.4s ease;
  }

  .modal-close {
    position: absolute;
    inset: 15px 15px auto auto;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--main-color);
    transition: var(--effectDuration);
  }

  .modal-close:hover {
    background-color: var(--button-hover-color);
    scale: 1.1;
  }

  .modal {
    display: flex;
    flex-direction: column;
    justify-content: space-between;

    position: relative;
    width: 100%;
    min-height: 70vh;
    max-height: 90vh;

    padding: 50px 25px;
    background-color: var(--bgc-color-white);
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;

    transform: translateY(0);
    transition: all 0.5s ease;
  }

  .modal-overlay.is-hidden .modal {
    transform: translateY(100%);
  }

  .modal h3 {
    font-size: var(--fs-modal-h3);
    align-self: center;
    margin-bottom: 15px;
  }

  .modal-form {
    display: flex;
    flex-direction: column;
    flex-grow: 1; /* растягиваем форму на доступное пространство */
    justify-content: flex-start; /* чтобы поля оставались сверху */
  }

  .field {
    display: flex;
    flex-direction: column;
  }

  .modal-input {
    height: 60px;
    border-radius: 30px;
    background-color: #d8d8d857;
    outline: none;
    border: none;
    padding: 0 25px 0 25px;
  }

  .error {
    font-size: 13px;
    color: red;
    min-height: 16px;
  }

  .modal-input.error-input {
    border: 1px solid red;
  }

  .modal-btn {
    height: 60px;
    border-radius: 30px;
    background-color: var(--main-color);
    transition: var(--effectDuration);
  }

  .modal-btn:hover {
    background-color: var(--button-hover-color);
  }

  .modal-policy {
    justify-self: end;
    font-size: 13px;
    color: #2525257b;
    text-align: center;
    margin-top: 15px;
  }

  .modal-policy span {
    text-decoration: underline;
    cursor: pointer;
  }

  .form-response {
    display: none;
    height: 60px;
    border-radius: 30px;
    background-color: #d8d8d857;
    outline: none;
    border: none;
    padding: 0 25px;
    margin-bottom: 15px;
    font-size: 14px;
    line-height: 60px;
    box-sizing: border-box;
    transition: all 0.3s;
  }

  .form-response.show {
    display: block;
    opacity: 1;
  }

  .form-response.success {
    border: 1px solid green;
    background-color: #e6ffe6;
    color: green;
  }

  .form-response.error {
    border: 1px solid red;
    background-color: #ffe6e6;
    color: red;
  }

  @media (min-width: 768px) {
    .modal-overlay {
      align-items: center;
    }

    .modal {
      width: 420px;
      min-height: auto;
      max-height: none;
      height: 500px;
      border-radius: 20px;
      opacity: 1;
      transition: all 0.3s ease-in-out;
      transform: none;
    }

    .modal-overlay.is-hidden .modal {
      opacity: 0;
      transform: none;
    }
  }

  @media (min-width: 1200px) {
    .modal {
      width: 500px;
      /* height: 600px; */
    }

    .modal-input {
      font-size: 20px;
    }

    .modal-btn {
      font-size: 20px;
    }

    .modal-policy {
      font-size: 18px;
    }
  }
</style>

<script>
  import { initPrivacyModal } from '../scripts/privacyModal';

  const callbackBtn = document.querySelector('.appointment-button');
  const modalCloseBtn = document.querySelector('.modal-close');
  const modalOverlay = document.querySelector('.modal-overlay');
  const callbackForm = document.querySelector<HTMLFormElement>('#callback-form');
  const phoneInput = document.querySelector<HTMLInputElement>('input[name="phone"]');

  const nameError = document.querySelector<HTMLElement>('[data-error="name"]');
  const phoneError = document.querySelector<HTMLElement>('[data-error="phone"]');
  const responseBlock = document.querySelector<HTMLElement>('#form-response');

  initPrivacyModal('.personal-data');

  // --------------------------
  // Маска для телефона: XXX-XXX-XX-XX, первая цифра 0
  // --------------------------
  phoneInput?.addEventListener('input', () => {
    let value = phoneInput.value.replace(/\D/g, ''); // оставляем только цифры
    if (value.length > 10) value = value.slice(0, 10);

    // Если первая цифра не 0, автоматически исправляем на 0
    if (value.length > 0 && value[0] !== '0') {
      value = '0' + value.slice(1);
    }

    const parts = [];
    if (value.length > 0) parts.push(value.slice(0, 3));
    if (value.length >= 4) parts.push(value.slice(3, 6));
    if (value.length >= 7) parts.push(value.slice(6, 8));
    if (value.length >= 9) parts.push(value.slice(8, 10));

    phoneInput.value = parts.join('-');
  });

  // --------------------------
  // Закрытие модалки
  // --------------------------
  const closeModal = () => {
    document.body.classList.remove('no-scroll');
    modalOverlay?.classList.add('is-hidden');

    callbackForm?.reset();

    if (nameError) nameError.textContent = '';
    if (phoneError) phoneError.textContent = '';

    if (responseBlock) {
      responseBlock.textContent = '';
      responseBlock.classList.remove('success', 'error', 'show');
    }

    callbackForm?.querySelectorAll('input').forEach((input) => {
      input.classList.remove('error-input');
    });
  };

  // --------------------------
  // Открытие модалки
  // --------------------------
  callbackBtn?.addEventListener('click', () => {
    document.body.classList.add('no-scroll');
    modalOverlay?.classList.remove('is-hidden');
    if (callbackForm) {
      const startInput = callbackForm.querySelector<HTMLInputElement>('input[name="startTime"]');
      if (startInput) startInput.value = Date.now().toString();
    }
  });

  modalCloseBtn?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.code === 'Escape') closeModal();
  });
  modalOverlay?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.modal')) closeModal();
  });

  // --------------------------
  // Валидация формы
  // --------------------------
  function validate(formData: FormData): { isValid: boolean; name: string; phone: string } {
    let isValid = true;

    // Сброс подсветки перед проверкой
    callbackForm
      ?.querySelectorAll('input')
      .forEach((input) => input.classList.remove('error-input'));
    if (nameError) nameError.textContent = '';
    if (phoneError) phoneError.textContent = '';

    const name = formData.get('name')?.toString().trim() || '';
    const phone = formData.get('phone')?.toString().trim() || '';

    const nameRegex = /^[А-Яа-яЁёІЇЄҐієїґA-Za-z\s]{1,30}$/;
    if (!nameRegex.test(name)) {
      if (nameError) nameError.textContent = 'Імʼя повинно містити тільки букви (до 30 символів)';
      isValid = false;
      callbackForm
        ?.querySelector<HTMLInputElement>('input[name="name"]')
        ?.classList.add('error-input');
    }

    // Телефон: XXX-XXX-XX-XX, первая цифра 0
    const phoneRegex = /^0\d{2}-\d{3}-\d{2}-\d{2}$/;
    if (!phoneRegex.test(phone)) {
      if (phoneError)
        phoneError.textContent = 'Телефон повинен починатися з 0 та бути у форматі XXX-XXX-XX-XX';
      isValid = false;
      callbackForm
        ?.querySelector<HTMLInputElement>('input[name="phone"]')
        ?.classList.add('error-input');
    }

    return { isValid, name, phone };
  }

  // --------------------------
  // Отправка формы
  // --------------------------
  callbackForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!callbackForm || !responseBlock) return;

    const formData = new FormData(callbackForm);

    // Honeypot и таймер антиспам
    const honeypot = formData.get('_honeypot')?.toString();
    const startTime = Number(formData.get('startTime'));
    if (honeypot) return;
    if (Date.now() - startTime < 1500) return;

    const { isValid, name, phone } = validate(formData);
    if (!isValid) return;

    // Сброс блока ответа перед новой попыткой
    responseBlock.textContent = '';
    responseBlock.classList.remove('success', 'error', 'show');

    try {
      const response = await fetch('https://siriusdental.com.ua/api/callback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone }),
      });

      const data = await response.json();

      if (response.ok && data.ok) {
        // Успех
        responseBlock.textContent = 'Заявку прийнято ✅';
        responseBlock.classList.add('success', 'show');
        responseBlock.classList.remove('error');

        // Снять красную подсветку после успешной отправки
        callbackForm
          .querySelectorAll('input')
          .forEach((input) => input.classList.remove('error-input'));

        callbackForm.reset();

        // Автозакрытие через 3 сек
        setTimeout(closeModal, 3000);
      } else {
        // Ошибка сервера
        responseBlock.textContent = data.error || 'Сталася помилка ❌ Спробуйте ще раз';
        responseBlock.classList.add('error', 'show');
        responseBlock.classList.remove('success');
      }
    } catch (err) {
      console.error(err);
      responseBlock.textContent = 'Сталася помилка ❌ Спробуйте ще раз';
      responseBlock.classList.add('error', 'show');
      responseBlock.classList.remove('success');
    }
  });
</script>
