---
import '../styles/main.css';
import LogoIcon from '../assets/icons/Sirius-logo.svg';
---

<footer class="footer">
  <div class="container">
    <a href="#top" class="logo-wrapper">
      <LogoIcon class="logo" />
      <div class="name-wrapper">
        <p>Сіріус</p>
        <p>стоматологічний центр</p>
      </div>
    </a>
    <p class="privacy">Політика конфіденційності</p>
    <p class="copyright">© 2026 Сіріус. Всі права захищені.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 20px;
    background-color: var(--bgc-footer);
  }
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .footer p {
    font-size: var(--fs-footer);
    color: var(--text-color-white);
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-wrapper p:first-child {
    font-size: 18px;
    color: var(--main-color);
  }

  .logo {
    fill: var(--main-color);
  }

  .privacy {
    text-decoration: underline;
    cursor: pointer;
  }

  .privacy:hover {
    text-shadow: 2px 3px 4px rgba(68, 133, 90, 0.845);
  }

  @media (min-width: 768px) {
    .logo-wrapper p:first-child {
      font-size: 22px;
    }
  }

  @media (min-width: 1200px) {
    .container {
      flex-direction: row;
      justify-content: space-between;
      align-items: end;
    }
  }
</style>

<script>
  const privacyButton = document.querySelector('.privacy');
  const privacyModal = document.querySelector('.privacy-overlay');
  const privacyCloseBtn = document.querySelector('.privacy-close') as HTMLElement;
  let lastFocused: HTMLElement | null = null;

  const closeHandler = () => {
    document.body.classList.remove('no-scroll');
    privacyModal?.classList.add('is-hidden');

    lastFocused?.focus();
  };

  privacyButton?.addEventListener('click', () => {
    lastFocused = document.activeElement as HTMLElement;

    privacyModal?.classList.remove('is-hidden');
    document.body.classList.add('no-scroll');

    privacyCloseBtn?.focus();
  });

  privacyCloseBtn?.addEventListener('click', closeHandler);

  document.addEventListener('keydown', (e) => {
    if (e.code === 'Escape') {
      closeHandler();
    }
  });

  privacyModal?.addEventListener('click', (e) => {
    const isOverlay = e.target === e.currentTarget;
    if (isOverlay) {
      closeHandler();
    }
  });
</script>
