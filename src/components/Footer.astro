---
import '../styles/main.css';
import LogoIcon from '../assets/icons/Sirius-logo.svg';
---

<footer class="footer">
  <div class="container">
    <a href="#top" class="logo-wrapper">
      <LogoIcon class="logo" />
      <div class="name-wrapper">
        <p>Сіріус</p>
        <p>стоматологічний центр</p>
      </div>
    </a>
    <p class="privacy">Політика конфіденційності</p>
    <p class="copyright">© 2026 Сіріус. Всі права захищені.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 20px;
    background-color: var(--bgc-footer);
  }
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .footer p {
    font-size: var(--fs-footer);
    color: var(--text-color-white);
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
  }

  .logo-wrapper:hover {
    transform: translateY(-2px);
  }

  .logo-wrapper p:first-child {
    font-size: 18px;
    color: var(--main-color);
  }

  .logo {
    fill: var(--main-color);
    transition: filter 0.3s ease;
  }

  .logo-wrapper:hover .logo {
    filter: drop-shadow(0 0 6px rgba(47, 158, 136, 0.6));
  }

  .privacy {
    position: relative;
    display: inline-block;
    color: var(--text-color-white);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .privacy::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -3px;
    width: 0%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--main-color), transparent);
    transform: translateX(-50%);
    transition: all 0.4s ease;
  }

  .privacy:hover {
    color: var(--main-color);
    text-shadow: 0 0 8px rgba(47, 158, 136, 0.6);
  }

  .privacy:hover::after {
    width: 100%;
  }

  @media (min-width: 768px) {
    .logo-wrapper p:first-child {
      font-size: 22px;
    }
  }

  @media (min-width: 1200px) {
    .container {
      flex-direction: row;
      justify-content: space-between;
      align-items: end;
    }
  }
</style>

<script>
  import { initPrivacyModal } from '../scripts/privacyModal';

  initPrivacyModal('.privacy');
</script>
