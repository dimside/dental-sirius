---

<section id="services" class="services">
  <div class="container">
    <div class="wrapper">
      <h2 class="title-h2">Послуги</h2>

      <ul class="ul-list">
        {
          services.map((service) => (
            <li class="li-item">
              <Image src={service.img} alt={service.title} class="img" />
              <button class="btn-services" data-modal={service.id}>
                <h3 class="title">{service.title}</h3>
              </button>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  {
    services.map((service) => (
      <div id={service.id} class="backdrop is-hidden">
        <div class="modal-content">
          <button class="close-btn" aria-label="Закрити">
            <img src={close} alt="" />
          </button>
          <h3>{service.title}</h3>
          <div class="modal-body">
            <ul class="modal-list">
              {service.text.split('\n').map((paragraph, index, arr) => {
                if (paragraph.startsWith('* ')) {
                  const isLast = !arr.slice(index + 1).some((line) => line.startsWith('* '));
                  return (
                    <li class={`modal-list-item ${isLast ? 'last-item' : ''}`}>
                      {paragraph.slice(2)}
                    </li>
                  );
                } else if (paragraph.trim() !== '') {
                  return <p class="modal-text">{paragraph}</p>;
                }
              })}
            </ul>
          </div>
        </div>
      </div>
    ))
  }
</section>

<style>
  .wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .title-h2 {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-color-black);
    text-align: center;
    gap: 20px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.588);
  }
  .title-h2::before,
  .title-h2::after {
    content: '';
    /* display: inline-block; */
    width: 19px;
    height: 4px;
    /* background-color: var(--main-color); */
    /* flex-shrink: 0; */
  }
  .title-h2::before {
    background: linear-gradient(90deg, transparent, var(--main-color));
  }
  .title-h2::after {
    background: linear-gradient(90deg, var(--main-color), transparent);
  }
  .ul-list {
    margin-top: 40px;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    padding: 0;
    gap: 20px;
  }

  .li-item {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 345px;
    height: 245px;
    background-size: cover;
    background-position: center;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
  }
  .li-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(75, 70, 100, 0.8);
    z-index: 1;
  }
  .img {
    height: 100%;
  }

  .btn-services {
    position: absolute;
    z-index: 2;
    width: 180px;
    height: 50px;
    border: none;
    background: none;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s ease;
    border-radius: 0;
  }
  .btn-services h3 {
    margin: 0;
    transition: opacity 0.3s ease;
  }
  .btn-services::after {
    content: 'ДЕТАЛЬНІШЕ';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background-color: var(--button-hover-color);
    border-radius: 47px;
    opacity: 0;
    transform: translateY(10px); /* старт ниже */

    transition:
      opacity 0.4s ease,
      transform 0.4s ease;

    font-size: 18px;
    letter-spacing: 1px;
  }
  .li-item:hover .btn-services h3 {
    opacity: 0;
  }

  .li-item:hover .btn-services::after {
    opacity: 1;
    transform: translateY(0);
  }

  .modal-content {
    position: absolute;
    top: 20px;
    background-color: #ffffff;
    padding: 30px;
    width: 90%;
    max-width: 1000px;
    border-radius: 12px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
    transform: scale(0.8);
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .backdrop:not(.is-hidden) .modal-content {
    transform: scale(1);
  }

  .close-btn {
    position: absolute;
    inset: 15px 15px auto auto;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--main-color);
    transition: var(--effectDuration);
    cursor: pointer;
  }
  .close-btn:hover {
    background-color: var(--button-hover-color);
    scale: 1.1;
  }
  .modal-title {
    color: var(--main-color);
    margin-bottom: 15px;
    text-transform: uppercase;
  }

  .modal-text {
    margin-bottom: 1.5rem;
  }

  .modal-list {
    list-style: none;
  }

  .modal-list-item {
    position: relative;
    margin-bottom: 0.5rem;
    padding-left: 2rem;
  }

  .modal-list-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.15rem;
    width: 1rem;
    height: 1rem;
    background-color: #ccc;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-list-item::after {
    content: '';
    position: absolute;
    left: 0.25rem;
    width: 0.5rem;
    height: 0.5rem;
    top: 0.4rem;
    background-color: var(--main-color);
    border-radius: 50%;
  }
  .modal-list-item.last-item {
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .ul-list {
      margin-top: 60px;
    }
    .title-h2::before,
    .title-h2::after {
      width: 25px;
    }
    .modal-content {
      top: 15%;
    }
    .li-item {
      width: 352px;
      height: 252px;
    }
    .btn-services {
      width: 190px;
    }
  }
  @media (min-width: 1200px) {
    .ul-list {
      margin-top: 70px;
    }
    .li-item {
      width: 360px;
      height: 260px;
    }
    .btn-services {
      width: 205px;
    }
    .modal-content {
      padding: 50px;
      top: 25%;
    }
  }
</style>

<script>
  const openButtons = document.querySelectorAll('.btn-services');
  const backdrops = document.querySelectorAll('.backdrop');

  openButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const modalId = btn.getAttribute('data-modal');
      const modal = modalId && document.getElementById(modalId);
      if (modal) {
        modal.classList.remove('is-hidden');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  backdrops.forEach((backdrop) => {
    backdrop.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === backdrop || target.closest('.close-btn')) {
        backdrop.classList.add('is-hidden');
        document.body.style.overflow = '';
      }
    });
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const activeModal = document.querySelector('.backdrop:not(.is-hidden)');
      if (activeModal) {
        activeModal.classList.add('is-hidden');
        document.body.style.overflow = '';
      }
    }
  });
</script>
