---
import { Image } from 'astro:assets';
import protezImg from '../assets/images/protez.webp';
import whiteningImg from '../assets/images/whitening2.webp';
import implantImg from '../assets/images/implantation.webp';
import surgeryImg from '../assets/images/ambulator2.jpg';
import paroImg from '../assets/images/health.webp';
import close from '../assets/icons/close.svg?url';
import { lazy } from 'astro:schema';

const services = [
  {
    id: 'protez',
    title: 'ГІГІЄНА РОТОВОЇ ПОРОЖНИНИ',
    img: whiteningImg,
    text: 'Відбілювання — це безпечна та неінвазивна процедура, яка дозволяє освітлити колір зубів і повернути усмішці природну яскравість. Результат не є постійним і залежить від індивідуальних особливостей емалі та способу життя пацієнта.\n\nУ середньому відбілювання дозволяє освітлити зуби на 5–7 відтінків. Процедура підходить пацієнтам різного віку, які мають природні зуби без пломб або коронок у зоні посмішки.\n\nТривалість ефекту може становити від 6 місяців до кількох років залежно від гігієни порожнини рота та харчових звичок. У стоматологічній клініці «Сіріус» у Трускавці використовуються сучасні системи професійного відбілювання.\n\nПісля процедури пацієнт отримує рекомендації щодо догляду за ротовою порожниною та засоби для зміцнення емалі і профілактики чутливості зубів.',
  },
  {
    id: 'whitening',
    title: 'УСІ ВИДИ ЛІКУВАННЯ ЗУБІВ',
    img: protezImg,
    text: 'Відбілювання — це безпечна та неінвазивна процедура, яка дозволяє освітлити колір зубів і повернути усмішці природну яскравість. Результат не є постійним і залежить від індивідуальних особливостей емалі та способу життя пацієнта.\n\nУ середньому відбілювання дозволяє освітлити зуби на 5–7 відтінків. Процедура підходить пацієнтам різного віку, які мають природні зуби без пломб або коронок у зоні посмішки.\n\nТривалість ефекту може становити від 6 місяців до кількох років залежно від гігієни порожнини рота та харчових звичок. У стоматологічній клініці «Сіріус» у Трускавці використовуються сучасні системи професійного відбілювання.\n\nПісля процедури пацієнт отримує рекомендації щодо догляду за ротовою порожниною та засоби для зміцнення емалі і профілактики чутливості зубів.',
  },
  {
    id: 'implant',
    title: 'УСІ ВИДИ ПРОТЕЗУВАННЯ РОТОВОЇ ПОРОЖНИНИ',
    img: implantImg,
    text: 'Імплантологія — це напрям стоматології, який займається відновленням втрачених зубів за допомогою сучасних імплантатів. Для спеціалістів клініки «Сіріус» зубний імплантат — це не просто конструкція, а важливий елемент відновлення функціональності, естетики та впевненості пацієнта.\n\nІмплантати зазвичай виготовляються з титану — біосумісного матеріалу, який добре інтегрується з кістковою тканиною. Вони виконують функцію штучного кореня, на який встановлюється коронка або мостовидна конструкція, що дозволяє повністю відновити зубний ряд.\n\nУ стоматологічній клініці «Сіріус» у місті Трускавець використовуються перевірені системи імплантатів від провідних світових виробників, які мають високі показники надійності, довговічності та клінічно доведену ефективність.',
  },
  {
    id: 'surgery',
    title: 'АМБУЛАТОРНА ХІРУРГІЯ ТА ІМПЛАНТОЛОГІЯ',
    img: surgeryImg,
    text: `Хірургічна стоматологія є одним із важливих напрямків сучасної стоматологічної практики. Часто вона є складовою ортодонтичного, пародонтологічного або ортопедичного лікування і спрямована на усунення патологій порожнини рота.

До амбулаторної хірургії належать процедури, пов’язані з:
* видаленням зубів, які неможливо зберегти;
* корекцією форми та об’єму м’яких тканин порожнини рота;
* кістковою пластикою та аугментацією;
* видаленням кіст і доброякісних новоутворень;
* зубозберігаючими операціями — апікальною резекцією, гемісекцією, хірургічним подовженням коронкової частини зуба.

У клініці «Сіріус» у Трускавці більшість процедур проводяться з використанням сучасних мікрохірургічних методик. Це дозволяє зменшити післяопераційний дискомфорт, набряки та значно прискорити процес загоєння.`,
  },
  {
    id: 'paro',
    title: 'ПАРОДОНТОЛОГІЯ (апаратом VECTOR)',
    img: paroImg,
    text: 'Пародонтологія — це розділ стоматології, який займається профілактикою, діагностикою та лікуванням захворювань тканин, що утримують зуби: ясен, кісткової тканини та періодонтальної зв’язки.\n\nОсновною причиною розвитку захворювань пародонту є накопичення бактерій у порожнині рота. Зубний наліт та камінь викликають хронічне запалення, яке поступово руйнує тканини, що оточують зуби.\n\nНайпоширенішими захворюваннями пародонту є гінгівіт та пародонтит. Гінгівіт проявляється запаленням і кровоточивістю ясен та часто виникає через недостатню гігієну. Додатковими факторами ризику можуть бути гормональні зміни, неправильний прикус або неякісні ортопедичні конструкції.\n\nЯкщо гінгівіт не лікувати, він може перейти у пародонтит — більш серйозне захворювання, яке супроводжується руйнуванням кісткової тканини та рухливістю зубів. Куріння та цукровий діабет значно підвищують ризик розвитку цієї патології.\n\nСпеціалісти стоматологічної клініки «Сіріус» у Трускавці застосовують сучасні консервативні та хірургічні методи лікування захворювань пародонту, що дозволяє зберегти здоров’я ясен та зубів на довгі роки.',
  },
];
---

<section id="services" class="services">
  <div class="container">
    <div class="wrapper">
      <h2 class="title-h2">Послуги</h2>
      <p class="title-consultacia">Консультація - безкоштовно!</p>
      <ul class="ul-list">
        {
          services.map((service) => (
            <li class="li-item">
              <Image
                src={service.img}
                alt={service.title}
                class="img"
                loading="lazy"
                width={360}
                height={260}
                sizes="(max-width: 767px) 345px, (max-width: 1199px) 352px, 360px"
              />
              <div class="btn-services">
                <h3 class="title">{service.title}</h3>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- {
    services.map((service) => (
      <div
        id={service.id}
        class="backdrop is-hidden"
        role="dialog"
        aria-modal="true"
        aria-labelledby={`${service.id}-title`}
      >
        <div class="modal-content">
          <button class="close-btn" aria-label="Закрити">
            <img src={close} alt="Закрити" />
          </button>
          <h3>{service.title}</h3>
          <div class="modal-body">
            <ul class="modal-list">
              {service.text.split('\n').map((paragraph, index, arr) => {
                if (paragraph.startsWith('* ')) {
                  const isLast = !arr.slice(index + 1).some((line) => line.startsWith('* '));
                  return (
                    <li class={`modal-list-item ${isLast ? 'last-item' : ''}`}>
                      {paragraph.slice(2)}
                    </li>
                  );
                } else if (paragraph.trim() !== '') {
                  return <p class="modal-text">{paragraph}</p>;
                }
              })}
            </ul>
          </div>
        </div>
      </div>
    ))
  } -->
</section>

<style>
  .wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .title-h2 {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-color-black);
    text-align: center;
    gap: 20px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.588);
  }
  .title-h2::before,
  .title-h2::after {
    content: '';
    width: 19px;
    height: 4px;
  }
  .title-h2::before {
    background: linear-gradient(90deg, transparent, var(--main-color));
  }
  .title-h2::after {
    background: linear-gradient(90deg, var(--main-color), transparent);
  }
  .title-consultacia {
    display: block;
    width: fit-content;
    margin-top: 20px;
    padding: 10px 25px;

    font-weight: 700;
    text-transform: uppercase;
    text-align: center;
    line-height: 1.2;

    color: var(--main-color);
    border: 2px solid var(--main-color);
    border-radius: 50px;

    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    background-color: rgba(255, 255, 255, 0.8);
  }

  .ul-list {
    margin-top: 40px;
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    list-style: none;
    padding: 0;
    gap: 20px;
  }

  .li-item {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 345px;
    height: 245px;
    background-size: cover;
    background-position: center;
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    /* cursor: pointer; */
  }
  .li-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(75, 70, 100, 0.8);
    z-index: 1;
  }
  .img {
    height: 100%;
  }

  .btn-services {
    position: absolute;
    z-index: 2;
    width: 180px;
    height: auto;
    border: none;
    background: none;
    color: #fff;
    font-weight: 700;
    cursor: default;
    overflow: hidden;
    transition: all 0.3s ease;
    border-radius: 0;

    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    /* padding: 0 10px; */
    box-sizing: border-box;
  }
  .btn-services h3 {
    margin: 0;
    line-height: 1.2;
    word-wrap: break-word;
    width: 100%;
    /* transition: opacity 0.3s ease; */
  }
  /* .btn-services::after {
    content: 'ДЕТАЛЬНІШЕ';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background-color: var(--button-hover-color);
    border-radius: 47px;
    opacity: 0;
    transform: translateY(10px);

    transition:
      opacity 0.4s ease,
      transform 0.4s ease;

    font-size: 18px;
    letter-spacing: 1px;
  } */
  /* .li-item:hover .btn-services h3 {
    opacity: 0;
  } */

  /* .li-item:hover .btn-services::after {
    opacity: 1;
    transform: translateY(0);
  } */

  .modal-content {
    position: absolute;
    top: 20px;
    background-color: #ffffff;
    padding: 30px;
    width: 90%;
    max-width: 1000px;
    border-radius: 12px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
    transform: scale(0.8);
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .backdrop:not(.is-hidden) .modal-content {
    transform: scale(1);
  }

  .close-btn {
    position: absolute;
    inset: 15px 15px auto auto;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: var(--main-color);
    transition: var(--effectDuration);
    /* cursor: pointer; */
  }
  .close-btn:hover {
    background-color: var(--button-hover-color);
    scale: 1.1;
  }
  .modal-title {
    color: var(--main-color);
    margin-bottom: 15px;
    text-transform: uppercase;
  }

  .modal-text {
    margin-bottom: 1.5rem;
  }

  .modal-list {
    list-style: none;
  }

  .modal-list-item {
    position: relative;
    margin-bottom: 0.5rem;
    padding-left: 2rem;
  }

  .modal-list-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.15rem;
    width: 1rem;
    height: 1rem;
    background-color: #ccc;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-list-item::after {
    content: '';
    position: absolute;
    left: 0.25rem;
    width: 0.5rem;
    height: 0.5rem;
    top: 0.4rem;
    background-color: var(--main-color);
    border-radius: 50%;
  }
  .modal-list-item.last-item {
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .ul-list {
      margin-top: 60px;
    }
    .title-h2::before,
    .title-h2::after {
      width: 25px;
    }
    .title-consultacia {
      margin-top: 40px;
    }
    .modal-content {
      top: 15%;
    }
    .li-item {
      width: 352px;
      height: 252px;
    }
    .btn-services {
      width: 200px;
      /* height: 70px; */
    }
  }
  @media (min-width: 1200px) {
    .ul-list {
      margin-top: 70px;
    }
    .li-item {
      width: 360px;
      height: 260px;
    }

    .btn-services {
      width: 260px;
      /* height: 80px; */
    }
    .modal-content {
      padding: 50px;
      top: 25%;
    }
  }
</style>

