---
import { Image } from 'astro:assets';
import bgImage from '../assets/images/bcg2.webp';
import bgImage2 from '../assets/images/offer__bg-fig-new.png';
import sprite from '../assets/icons/sprite.svg?url';
---

<section class="hero">
  <Image
    src={bgImage}
    alt="Стоматологія в Трускавці «Сіріус»"
    class="hero-bg"
    loading="eager"
    fetchpriority="high"
    quality={80}
  />

  <div class="hero-bg-decor" style={`--hero-image2: url(${bgImage2})`}></div>

  <div class="container">
    <h1>Стоматологія в Трускавці «Сіріус» — для людей та про людей!</h1>

    <p class="hero-text">
      Професійна команда, преміальне обладнення, сучасні методи лікування і атмосфера комфорту -
      наші головні переваги.
    </p>

    <button class="appointment-button" aria-label="Замовити зворотній дзвінок">
      <span>Зворотній дзвінок</span>
      <svg class="svg menu">
        <use xlink:href={`${sprite}#right-arrow`}></use>
      </svg>
    </button>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 70vh;
    min-height: 400px;
    max-height: 800px;
    color: var(--text-color-white);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 65%;
    z-index: 0;
  }

  .hero-bg-decor {
    position: absolute;
    inset: 0;
    background-image: var(--hero-image2);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    z-index: 1;
    pointer-events: none;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(46, 47, 66, 0.6) 0%,
      rgba(46, 47, 66, 0.3) 60%,
      rgba(46, 47, 66, 0.6) 100%
    );
    z-index: 2;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.03) 0 2px,
      transparent 2px 10px
    );
    z-index: 4;
    pointer-events: none;
  }

  .hero > .container {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 30px;
    max-height: none;
    padding: 0 1rem;
  }

  .hero h1 {
    font-size: clamp(30px, 5vw, 72px);
    line-height: 1.1;
  }

  .hero-text {
    line-height: 1.68;
    font-size: clamp(16px, 2.5vw, 24px);
  }

  .appointment-button {
    display: flex;
    justify-content: center;
    align-items: center;
    width: clamp(220px, 60%, 320px);
    height: clamp(45px, 8vw, 70px);
    border-radius: 25px;
    background-color: #1cae91c9;
    text-transform: uppercase;
    transition: var(--effectDuration);
  }

  .appointment-button svg {
    width: 20px;
    height: 10px;
    margin-left: 10px;
  }

  .appointment-button:hover {
    background-color: var(--button-hover-color);
    transform: translateY(-3px);
  }

  @media (orientation: landscape) and (max-width: 767px) {
    .hero {
      height: 60vh;
    }

    .hero > .container {
      padding: 1.5rem;
    }

    .hero-bg {
      object-position: center;
    }

    .appointment-button {
      width: 50%;
      height: 50px;
    }
  }

  @media (min-width: 768px) {
    .hero > .container {
      justify-content: space-between;
      gap: 40px;
    }

    .hero-bg {
      object-position: center;
    }

    .appointment-button {
      width: 320px;
      height: 70px;
      border-radius: 35px;
    }
  }
</style>
