---
import bgImage2 from '../assets/images/offer__bg-fig-new.png?url';
import bcgImage from '../assets/images/background-img.webp?url';
import bcgImage2 from '../assets/images/bcg2.webp?url';
import sprite from '../assets/icons/sprite.svg?url';
import '../styles/main.css';
---

<section class="hero" style={`--hero-image: url(${bcgImage2}); --hero-image2: url(${bgImage2})`}>
  <div class="container">
    <h1>Стоматологічний центр «Сіріус» - для людей та про людей!</h1>
    <p class="hero-text">
      Професійна команда, преміальне обладнення, сучасні методи лікування і атмосфера комфорту -
      наші головні переваги.
    </p>
    <button class="appointment-button"
      ><span>Зворотній дзвінок</span><svg class="svg menu">
        <use xlink:href={`${sprite}#right-arrow`}></use>
      </svg>
    </button>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;

    width: 100%;
    height: 70vh;
    max-height: 800px;

    margin-left: auto;
    margin-right: auto;
    color: var(--text-color-white);

    background-color: var(--hero-bcg-color);
    background-image:
      linear-gradient(
        to bottom,
        rgba(46, 47, 66, 0.6) 0%,
        rgba(46, 47, 66, 0.3) 60%,
        rgba(46, 47, 66, 0.6) 100%
      ),
      var(--hero-image2), var(--hero-image);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.03) 0 2px,
      transparent 2px 10px
    );
    z-index: 1;
    pointer-events: none;
  }

  .hero > .container {
    position: relative;
    z-index: 2;
  }

  .hero h1 {
    font-size: clamp(28px, 5vw, 72px);
  }

  .container {
    display: flex;
    flex-grow: 1;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 30px;

    max-height: 400px;
  }

  .hero-text {
    line-height: 1.68;
    color: var(--text-color-white);
    font-size: clamp(16px, 2.5vw, 24px);
  }

  .appointment-button {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 260px;
    height: 50px;
    border-radius: 25px;
    background-color: #1cae91c9;
    text-transform: uppercase;
    transition: var(--effectDuration);
  }

  .appointment-button svg {
    width: 20px;
    height: 10px;
    margin-left: 10px;
  }

  .appointment-button:hover {
    background-color: var(--button-hover-color);
    transform: translateY(-3px);
  }

  @media (min-width: 768px) {
    .container {
      justify-content: space-between;
    }

    h1 {
      line-height: 1.1;
    }

    .appointment-button {
      width: 320px;
      height: 70px;
      border-radius: 35px;
    }
  }
</style>
