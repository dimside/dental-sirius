---
import HandTap from '../assets/icons/hand.svg';
---

<button type="button" class="promotion" id="promotion" aria-label="Відкрити акцію">
  <div class="border">
    <div class="wrapper">
      <p class="text">Акція</p>
      <HandTap class="icon" />
    </div>
    <p class="advert">Консультація - Безкоштовно!</p>
  </div>
</button>

<style>
  .promotion {
    position: fixed;
    bottom: 90px;
    left: 10px;
    z-index: 997;
    width: 65px;
    min-width: 65px;
    height: 65px;
    border-radius: 999px;
    background: #424056;
    color: var(--text-color-white);
    cursor: pointer;
    padding: 6px;
    box-sizing: border-box;

    transition:
      width 550ms cubic-bezier(0.6, 0, 0.4, 1) 380ms,
      border-radius 550ms cubic-bezier(0.6, 0, 0.4, 1) 380ms;
  }

  .promotion.active {
    width: 280px;

    transition:
      width 650ms cubic-bezier(0.34, 1.56, 0.64, 1) 0ms,
      border-radius 650ms cubic-bezier(0.34, 1.56, 0.64, 1) 0ms;
  }

  .border {
    width: 100%;
    height: 100%;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 999px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .wrapper {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.28s ease;
  }

  .promotion.active .wrapper {
    opacity: 0;
    transform: scale(0.65);
  }

  .text,
  .icon {
    position: absolute;
  }

  .text {
    font-size: 11px;
    text-transform: uppercase;
    animation: textCycle 4s infinite;
  }

  .icon {
    width: 34px;
    height: 34px;
    fill: white;
    animation: iconCycle 4s infinite;
  }

  .advert {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-35%, -50%);
    opacity: 0;
    white-space: nowrap;
    font-size: 18px;
    transition: all 0.35s ease;
  }

  .promotion.active .advert {
    opacity: 1;
    transform: translate(-50%, -50%);
  }

  @keyframes textCycle {
    0% {
      opacity: 0;
      transform: scale(1);
    }
    40% {
      opacity: 1;
      transform: scale(1.2);
    }
    50% {
      opacity: 0;
      transform: scale(0.9);
    }
    100% {
      opacity: 0;
    }
  }

  @keyframes iconCycle {
    0% {
      opacity: 0;
    }
    45% {
      opacity: 0;
    }
    50% {
      opacity: 0;
      transform: scale(0.8);
    }
    60% {
      opacity: 1;
      transform: scale(1.2);
    }
    70% {
      opacity: 1;
      transform: scale(0.8);
    }
    80% {
      opacity: 1;
      transform: scale(1.2);
    }
    100% {
      opacity: 0;
      transform: scale(0.8);
    }
  }

  @media (min-width: 1200px) {
    .promotion {
      left: 80px;
    }
  }
</style>

<script>
  const promotion = document.querySelector('#promotion');

  if (promotion) {
    promotion.addEventListener('click', () => {
      promotion.classList.add('active');

      setTimeout(() => {
        promotion.classList.remove('active');
      }, 3000);
    });
  }
</script>
