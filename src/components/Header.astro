---
import sprite from '../assets/icons/sprite.svg?url';
import '../styles/main.css';
---

<header id="top">
  <div class="nav-panel">
    <div class="container">
      <div class="logo-wrapper">
        <a href="#top"
          ><svg class="svg logo">
            <use xlink:href={`${sprite}#Sirius-logo`}></use>
          </svg>
        </a>
        <div class="name-wrapper">
          <p>Сіріус</p>
          <p>стоматологічний центр</p>
        </div>
      </div>

      <nav class="main-nav">
        <ul>
          <li><a href="#about">Про клініку</a></li>
          <li><a href="#advantages">Переваги</a></li>
          <li><a href="#services">Послуги</a></li>
          <li><a href="#team">Команда</a></li>
          <li><a href="#gallery">Фото</a></li>
          <li><a href="#prices">Ціни</a></li>
          <li><a href="#contacts">Контакти</a></li>
        </ul>
      </nav>
      <button type="button" class="menu-button">
        <svg class="svg menu">
          <use xlink:href={`${sprite}#menu`}></use>
        </svg></button
      >
    </div>
  </div>
  <div class="nav-placeholder"></div>
  <div class="nav-sentinel"></div>
  <div class="info-panel">
    <div class="container">
      <div class="address-wrapper">
        <svg class="svg info">
          <use xlink:href={`${sprite}#location`}></use>
        </svg>
        <div>
          <a href="https://maps.app.goo.gl/snzTugUu8miywrRs7" target="_blank" class="location"
            >м. Трускавец, вул. Суховоля, 50, 2 этаж, офис 1</a
          >
        </div>
      </div>

      <div class="phone-wrapper">
        <svg class="svg info">
          <use xlink:href={`${sprite}#call`}></use>
        </svg>
        <div><a href="tel:0674764995" class="phone">(067)476-49-95</a></div>
        <span class="divider">|</span>
        <div><a href="tel:0637415529" class="phone">(063)741-55-29</a></div>
        <span class="divider">|</span>
        <div><a href="tel:0962568070" class="phone">(096)256-80-70</a></div>
      </div>
    </div>
  </div>
</header>

<style>
  header {
    display: flex;
    flex-direction: column;
  }

  .nav-panel {
    padding: 15px 0;
  }

  .nav-panel.fixed {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .nav-panel .container {
    display: flex;
    justify-content: space-between;
  }

  .main-nav {
    display: none;
    font-size: var(--fs-nav-panel);
    font-weight: 400;
    color: #656565;
  }

  .nav-panel button {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 50px;
    height: 50px;
    background-color: var(--main-color);
    transition: var(--effectDuration);
  }

  .menu-button.fixed {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 988;
  }

  .nav-panel button:hover {
    background-color: var(--button-hover-color);
  }

  button .svg.menu {
    width: 40px;
    height: 40px;
    transition: var(--effectDuration);
  }

  button:hover .svg.menu {
    scale: 1.1;
  }

  .logo-wrapper {
    display: flex;
  }

  .name-wrapper {
    display: flex;
    flex-direction: column;
  }

  .nav-panel p:first-of-type {
    font-size: 30px;
    font-weight: 500;
    color: #3d3f96;
    line-height: 1.06;
  }

  .nav-panel p:last-of-type {
    font-size: 18px;
    font-weight: 400;
    color: #524d66;
  }

  .nav-panel li {
    transition: var(--effectDuration);
  }

  .nav-panel li:hover {
    background-color: #51c2ab20;
    color: var(--main-color);
  }

  .info-panel {
    padding: 12px 0;
    background-color: var(--bgс-info-panel);
    color: var(--text-color-white);
    font-size: var(--fs-info-panel);
    font-weight: 400;
    line-height: 1.375;
  }

  .address-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 8px;
  }

  .svg.logo {
    width: 64px;
    height: 57px;
    margin-right: 6px;
  }

  .svg.info {
    width: 16px;
    height: 16px;
    margin-right: 10px;
  }

  .divider {
    margin: 0 12px;
    color: #837a96;
  }

  .divider:last-of-type {
    display: none;
  }

  .phone-wrapper {
    display: flex;
    flex-flow: wrap;
    justify-content: center;
    font-weight: 500;
  }

  .phone,
  .location {
    transition: opacity var(--effectDuration);
  }

  .phone:hover,
  .location:hover {
    opacity: 0.7;
  }

  .nav-sentinel {
    height: 1px;
  }

  @media (min-width: 768px) {
    header {
      display: flex;
      flex-direction: column-reverse;
    }

    .main-nav {
      display: flex;
      justify-content: end;
      align-items: center;
      flex-grow: 1;
    }

    .main-nav ul {
      display: flex;
      justify-content: end;
      gap: 10px;
    }

    .nav-panel.fixed {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 1000;
      background: var(--bgc-color-white);
    }

    .nav-placeholder {
      display: none;
      height: 80px;
    }

    .nav-panel.fixed + .nav-placeholder {
      display: block;
    }

    .nav-panel button {
      display: none;
    }

    .divider:last-of-type {
      display: block;
    }
  }

  @media (min-width: 1200px) {
    .svg.logo {
      width: 74px;
      height: 66px;
      margin-right: 20px;
    }

    .nav-panel p:first-of-type {
      font-size: 34px;
    }

    .nav-panel p:last-of-type {
      font-size: 22px;
    }

    .main-nav ul {
      gap: 20px;
    }
  }
</style>

<script>
  const navPanel = document.querySelector('.nav-panel');
  const navPanelSentinel = document.querySelector('.nav-sentinel');
  const heroSentinel = document.querySelector('.hero');
  const menuButton = document.querySelector('.menu-button');
  const burgerMenu = document.querySelector('.burger-menu');
  const closeButton = document.querySelector('.close-button');
  const menuList = document.querySelector('.menu-list');

  const openBurgerMenu = () => {
    if (burgerMenu) burgerMenu.classList.add('open');
    document.body.classList.add('no-scroll');
  };

  const closeBurgerMenu = () => {
    burgerMenu?.classList.remove('open');
    document.body.classList.remove('no-scroll');
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.target === navPanelSentinel) {
        navPanel?.classList.toggle('fixed', !entry.isIntersecting);
      }
      if (entry.target === heroSentinel) {
        menuButton?.classList.toggle('fixed', !entry.isIntersecting);
      }
    });
  });

  if (navPanelSentinel) observer.observe(navPanelSentinel);
  if (heroSentinel) observer.observe(heroSentinel);

  if (menuButton) menuButton.addEventListener('click', openBurgerMenu);
  if (closeButton) closeButton.addEventListener('click', closeBurgerMenu);

  document.addEventListener('keydown', (e) => {
    if (e.code === 'Escape') closeBurgerMenu();
  });

  burgerMenu?.addEventListener('click', (e) => {
    const target = e.target;
    if (target instanceof HTMLElement && !target.closest('.menu-list')) {
      closeBurgerMenu();
    }
  });

  menuList?.addEventListener('click', (e) => {
    const target = e.target;
    if (target instanceof HTMLElement && target.tagName === 'A') {
      closeBurgerMenu();
    }
  });
</script>
