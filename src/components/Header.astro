---
import sprite from '../assets/icons/sprite.svg?url';
import '../styles/main.css';
---

<header id="top">
  <div class="nav-panel">
    <div class="container">
      <div class="logo-wrapper">
        <a href="#top">
          <svg class="svg logo" role="img" aria-label="Стоматологія Сіріус у Трускавці">
            <title>Стоматологія Сіріус у Трускавці</title>
            <use xlink:href={`${sprite}#Sirius-logo`}></use>
          </svg>
        </a>
        <div class="name-wrapper">
          <p>Сіріус</p>
          <p>стоматологія Трускавця</p>
        </div>
      </div>

      <nav class="main-nav">
        <ul>
          <li><a href="#about">Про клініку</a></li>
          <li><a href="#advantages">Переваги</a></li>
          <li><a href="#services">Послуги</a></li>
          <li><a href="#team">Команда</a></li>
          <li><a href="#gallery">Фото</a></li>
          <!-- <li><a href="#prices">Ціни</a></li> -->
          <li><a href="#contacts">Контакти</a></li>
        </ul>
      </nav>

      <button type="button" class="menu-button" aria-label="Відкрити меню">
        <svg class="svg menu"><use xlink:href={`${sprite}#menu`}></use></svg>
      </button>
    </div>
  </div>

  <div class="nav-placeholder"></div>
  <div class="nav-sentinel"></div>

  <div class="info-panel">
    <div class="container">
      <div class="address-wrapper">
        <svg class="svg info"><use xlink:href={`${sprite}#location`}></use></svg>
        <a
          href="https://maps.app.goo.gl/Rw2n4PmrPexvUwce8"
          target="_blank"
          class="location"
          itemprop="address"
          itemscope
          itemtype="http://schema.org/PostalAddress"
        >
          <span itemprop="addressLocality">Трускавець</span>,
          <span itemprop="streetAddress">вул. Суховоля, 50, 2 поверх, каб. № 1</span>
        </a>
      </div>

      <div class="phone-wrapper">
        <svg class="svg info"><use xlink:href={`${sprite}#call`}></use></svg>
        <a href="tel:0674764995" class="phone" itemprop="telephone">(067)476-49-95</a>
        <span class="divider">|</span>
        <a href="tel:0637415529" class="phone" itemprop="telephone">(063)741-55-29</a>
        <span class="divider">|</span>
        <a href="tel:0962568070" class="phone" itemprop="telephone">(096)256-80-70</a>
      </div>
    </div>
  </div>
</header>

<style>
  header {
    display: flex;
    flex-direction: column;
  }

  .nav-panel {
    padding: 15px 0;
  }

  .nav-panel.fixed {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .nav-panel .container {
    display: flex;
    justify-content: space-between;
  }

  .main-nav {
    display: none;
    font-size: var(--fs-nav-panel);
    font-weight: 400;
    color: #656565;
  }

  .nav-panel button {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 50px;
    height: 50px;
    background-color: var(--main-color);
    transition: var(--effectDuration);
  }

  .menu-button.fixed {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 988;
  }

  .nav-panel button:hover {
    background-color: var(--button-hover-color);
  }

  button .svg.menu {
    width: 40px;
    height: 40px;
    transition: var(--effectDuration);
  }

  button:hover .svg.menu {
    scale: 1.1;
  }

  .logo-wrapper {
    display: flex;
  }

  .name-wrapper {
    display: flex;
    flex-direction: column;
  }

  .nav-panel p:first-of-type {
    font-size: 30px;
    font-weight: 500;
    color: #3d3f96;
    line-height: 1.06;
  }

  .nav-panel p:last-of-type {
    font-size: 18px;
    font-weight: 400;
    color: #524d66;
  }

  .info-panel {
    padding: 12px 0;
    background-color: var(--bgc-info-panel);
    color: var(--text-color-white);
    font-size: var(--fs-info-panel);
    font-weight: 400;
    line-height: 1.375;
  }

  .address-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 8px;
  }

  .svg.logo {
    width: 64px;
    height: 57px;
    margin-right: 6px;
  }

  .svg.info {
    width: 16px;
    height: 16px;
    margin-right: 10px;
  }

  .divider {
    margin: 0 12px;
    color: #837a96;
  }

  .divider:last-of-type {
    display: none;
  }

  .phone-wrapper {
    display: flex;
    flex-flow: wrap;
    justify-content: center;
    font-weight: 500;
  }

  .phone,
  .location {
    transition: all var(--effectDuration);
  }

  .phone,
  .location {
    position: relative;
    transition: all 0.3s ease;
  }

  .phone::after,
  .location::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0%;
    height: 2px;
    background: var(--main-color);
    transition: all 0.3s ease;
  }

  .phone:hover,
  .location:hover {
    color: var(--main-color);
  }

  .phone:hover::after,
  .location:hover::after {
    width: 100%;
  }

  .nav-sentinel {
    height: 1px;
  }

  @media (min-width: 768px) {
    header {
      display: flex;
      flex-direction: column-reverse;
    }

    .main-nav {
      display: flex;
      justify-content: end;
      align-items: center;
      flex-grow: 1;
    }

    .main-nav ul {
      display: flex;
      justify-content: end;
      gap: 10px;
    }

    .main-nav a {
      position: relative;
      color: inherit;
      transition: color 0.3s ease;
    }

    .main-nav a::after {
      content: '';
      position: absolute;
      left: 50%;
      bottom: 0;
      width: 0%;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--main-color), transparent);
      transform: translateX(-50%);
      transition: all 0.3s ease;
    }

    .main-nav a:hover {
      color: var(--main-color);
    }

    .main-nav a:hover::after {
      width: 100%;
    }

    .main-nav a.active {
      color: var(--main-color);
      font-weight: 600;
    }

    .nav-panel.fixed {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 990;

      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(10px);

      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .nav-placeholder {
      display: none;
      height: 80px;
    }

    .nav-panel.fixed + .nav-placeholder {
      display: block;
    }

    .nav-panel button {
      display: none;
    }

    .divider:last-of-type {
      display: block;
    }
  }

  @media (min-width: 1200px) {
    .svg.logo {
      width: 74px;
      height: 66px;
      margin-right: 20px;
    }

    .nav-panel p:first-of-type {
      font-size: 34px;
    }

    .nav-panel p:last-of-type {
      font-size: 22px;
    }

    .main-nav ul {
      gap: 20px;
    }
  }
</style>

<script>
  const navPanel = document.querySelector('.nav-panel');
  const navPanelSentinel = document.querySelector('.nav-sentinel');
  const heroSentinel = document.querySelector('.hero');
  const menuButton = document.querySelector('.menu-button');
  const burgerMenu = document.querySelector('.burger-menu');
  const closeButton = document.querySelector('.close-button');
  const menuList = document.querySelector('.menu-list');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.main-nav a');

  const sections: HTMLElement[] = Array.from(navLinks)
    .map((link) => {
      const id = link.getAttribute('href')?.slice(1);
      if (!id) return null;
      return document.getElementById(id);
    })
    .filter((section): section is HTMLElement => section !== null);

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const id = entry.target.id;
        const navLink = document.querySelector(`.main-nav a[href="#${id}"]`);
        if (entry.isIntersecting) {
          navLinks.forEach((link) => link.classList.remove('active'));
          navLink?.classList.add('active');
        }
      });
    },
    {
      root: null,
      rootMargin: '-50% 0px -50% 0px',
      threshold: 0,
    }
  );

  sections.forEach((section) => sectionObserver.observe(section));

  const openBurgerMenu = () => {
    if (burgerMenu) burgerMenu.classList.add('open');
    document.body.classList.add('no-scroll');
  };

  const closeBurgerMenu = () => {
    burgerMenu?.classList.remove('open');
    document.body.classList.remove('no-scroll');
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.target === navPanelSentinel) {
        navPanel?.classList.toggle('fixed', !entry.isIntersecting);
      }
      if (entry.target === heroSentinel) {
        menuButton?.classList.toggle('fixed', !entry.isIntersecting);
      }
    });
  });

  if (navPanelSentinel) observer.observe(navPanelSentinel);
  if (heroSentinel) observer.observe(heroSentinel);

  if (menuButton) menuButton.addEventListener('click', openBurgerMenu);
  if (closeButton) closeButton.addEventListener('click', closeBurgerMenu);

  document.addEventListener('keydown', (e) => {
    if (e.code === 'Escape') closeBurgerMenu();
  });

  burgerMenu?.addEventListener('click', (e) => {
    const target = e.target;
    if (target instanceof HTMLElement && !target.closest('.menu-list')) {
      closeBurgerMenu();
    }
  });

  menuList?.addEventListener('click', (e) => {
    const target = e.target;
    if (target instanceof HTMLElement && target.tagName === 'A') {
      closeBurgerMenu();
    }
  });
</script>
