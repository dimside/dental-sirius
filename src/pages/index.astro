---
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Advantages from '../components/Advantages.astro';
import Services from '../components/Services.astro';
import Team from '../components/Team.astro';
import Gallery from '../components/Gallery.astro';
import Contacts from '../components/Contacts.astro';
import Footer from '../components/Footer.astro';
import BurgerMenu from '../components/BurgerMenu.astro';
import Prices from '../components/Prices.astro';
import '../styles/main.css';
import Callback from '../components/Callback.astro';
import Privacy from '../components/Privacy.astro';
import Promotion from '../components/Promotion.astro';
---

<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
      Стоматологія в Трускавці «Сіріус» — лікування зубів, імплантація, протезування | Сіріус
    </title>
    <meta
      name="description"
      content="Стоматологія «Сіріус» у Трускавці — лікування зубів без болю, імплантація, протезування, чистка. Сучасне обладнання та досвідчені лікарі. Запис онлайн."
    />
    <link rel="canonical" href="https://siriusdental.com.ua/" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="192x192" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:title" content="Стоматологія в Трускавці «Сіріус» — лікування зубів" />
    <meta
      property="og:description"
      content="Стоматологія «Сіріус» у Трускавці — лікування зубів без болю, імплантація, протезування, чистка. Сучасне обладнання та досвідчені лікарі. Запис онлайн."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://siriusdental.com.ua/" />
    <meta property="og:image" content="https://siriusdental.com.ua/og-image.jpg" />
    <meta http-equiv="Content-Language" content="uk" />
    <meta name="generator" content={Astro.generator} />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Dentist",
        "@id": "https://siriusdental.com.ua/#dentist",
        "url": "https://siriusdental.com.ua/",
        "description": "Стоматологія «Сіріус» у Трускавці — лікування зубів без болю, імплантація, протезування, чистка. Сучасне обладнання та досвідчені лікарі.",
        "name": "Стоматологія Сіріус у Трускавці",
        "image": "https://siriusdental.com.ua/logo.svg",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Суховоля, 50, 2 поверх, офіс 1",
          "addressLocality": "Трускавець",
          "addressCountry": "UA"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 49.277355,
          "longitude": 23.497551
        },
        "telephone": ["+380674764995", "+380637415529", "+380962568070"],
        "openingHours": ["Mo-Fr 10:00-18:00", "Sa 10:00-13:00", "Su off"]
      }
    </script>
  </head>
  <>
    <Header />
    <main>
      <Hero />
      <About />
      <Advantages />
      <Services />
      <Team />
      <Gallery />
      <!-- <Prices /> -->
      <Contacts />
    </main>
    <Footer />
    <BurgerMenu />
    <Callback />
    <Privacy />
    <Promotion />
  </>
</html>
